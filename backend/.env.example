# ════════════════════════════════════════════════════════════════════
#  J.A.Y. — Just Assists You   ·   Backend configuration
#  Copy this file to .env and fill in the values you need.
#  Lines starting with # are comments — they are ignored.
# ════════════════════════════════════════════════════════════════════


# ── APPLICATION ──────────────────────────────────────────────────────
APP_NAME=J.A.Y.
APP_VERSION=0.1.0
DEBUG=false
SECRET_KEY=change-this-to-a-random-secret-key


# ── DATABASE ─────────────────────────────────────────────────────────
# SQLite (default — zero setup, works out of the box)
DATABASE_URL=sqlite+aiosqlite:///./jay.db
DATABASE_SYNC_URL=sqlite:///./jay.db

# PostgreSQL (optional — better for production / multi-user)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/jay
# DATABASE_SYNC_URL=postgresql://user:password@localhost:5432/jay


# ── AI PROVIDER KEYS ─────────────────────────────────────────────────
# You only need ONE of these to get started.
# Ollama needs no key — it runs fully locally.

# OpenRouter — recommended cloud option (free tier available)
# Sign up at https://openrouter.ai  →  Keys  →  Create key
# OPENROUTER_API_KEY=sk-or-v1-...

# Google Gemini (free tier: 15 req/min, 1 million tokens/day)
# https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=AIzaSy...

# OpenAI (paid)
# https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-proj-...

# Anthropic Claude (paid)
# ANTHROPIC_API_KEY=sk-ant-...


# ── OLLAMA (local AI) ─────────────────────────────────────────────────
# Install: https://ollama.ai/download
# Then run: ollama pull llama3.2:3b   (quickest start, 2 GB)
OLLAMA_BASE_URL=http://localhost:11434

# RAM budget for Ollama models on this machine (GB).
# 12 GB PC  →  7.0  (leaves room for OS + backend)
# 16 GB PC  →  10.0
# 8  GB PC  →  4.5
OLLAMA_RAM_BUDGET_GB=7.0

# Auto-pull a missing model the first time it is needed?
# true = convenient  |  false = only use already-installed models
OLLAMA_AUTO_PULL=true


# ── SMART ROUTING ─────────────────────────────────────────────────────
# ROUTING_MODE controls how J.A.Y. chooses which AI to use.
#   auto        → smart task-based routing (recommended)
#   ollama      → always use Ollama (fully offline)
#   openrouter  → always use OpenRouter
#   gemini      → always use Gemini
ROUTING_MODE=auto

# Fallback order when routing_mode=auto (comma-separated, left = highest priority)
ROUTING_FALLBACK_ORDER=ollama,openrouter,gemini


# ── PER-TASK MODEL OVERRIDES ──────────────────────────────────────────
# Leave blank ("") to let smart routing pick automatically.
# Set an exact model ID to force that model for the task type.
#
# Ollama model IDs:
#   llama3.2:3b                                   (2.0 GB — tiny/fast)
#   phi3:3.8b                                     (2.3 GB — tiny/fast, 128K ctx)
#   mistral:7b-instruct-q4_K_M                    (4.1 GB — great all-rounder)
#   llama3.1:8b-instruct-q4_K_M                   (4.7 GB — strong, 128K ctx)
#   deepseek-coder-v2:16b-lite-instruct-q4_K_M    (4.9 GB — best local code)
#   codellama:7b-instruct-q4_K_M                  (3.8 GB — code fallback)
#   mixtral:8x7b-instruct-v0.1-q2_K               (6.5 GB — powerful, slow)
#
# OpenRouter free model IDs:
#   meta-llama/llama-3.1-8b-instruct:free
#   meta-llama/llama-3.3-70b-instruct:free        ← best free cloud model
#   google/gemma-3-27b-it:free
#   deepseek/deepseek-r1:free                     ← best for reasoning/code
#   mistralai/mistral-7b-instruct:free

MODEL_QUICK=llama3.2:3b
MODEL_VOICE=llama3.2:3b
MODEL_CHAT=llama3.1:8b-instruct-q4_K_M
MODEL_CODE=deepseek-coder-v2:16b-lite-instruct-q4_K_M
MODEL_CODE_HEAVY=deepseek/deepseek-r1:free
MODEL_TRADING=mistral:7b-instruct-q4_K_M
MODEL_RESEARCH=meta-llama/llama-3.3-70b-instruct:free
MODEL_CREATIVE=google/gemma-3-27b-it:free
MODEL_PLAN=llama3.1:8b-instruct-q4_K_M
MODEL_ANALYSIS=meta-llama/llama-3.3-70b-instruct:free
MODEL_MEMORY=llama3.2:3b
MODEL_TOOL=mistral:7b-instruct-q4_K_M


# ── OPENROUTER FREE TIER QUOTA GUARDS ────────────────────────────────
# Conservative limits to avoid hitting the free tier ceiling.
# Set to 0 to disable a particular guard.
OR_FREE_DAILY_LIMIT=200        # max requests per model per day
OR_FREE_RPM_LIMIT=20           # max requests per minute per model
OR_FREE_TOKENS_PER_DAY=50000   # max tokens (in+out) per model per day
OR_EXHAUST_ERROR_THRESHOLD=5   # consecutive errors before marking exhausted


# ── GEMINI ────────────────────────────────────────────────────────────
GEMINI_DEFAULT_MODEL=gemini-1.5-flash


# ── VOICE ─────────────────────────────────────────────────────────────
# Wake words (comma-separated, lowercase)
# WAKE_WORDS=hey jay,wake up jay,j.a.y.

# Porcupine wake word engine (optional, more accurate)
# Sign up at https://picovoice.ai  →  free tier available
# PVPORCUPINE_ACCESS_KEY=...

# Edge TTS voice — full list: run `edge-tts --list-voices`
TTS_VOICE=en-US-AriaNeural
TTS_RATE=+0%
TTS_PITCH=+0Hz

# Whisper STT model size: tiny(75MB) | base(142MB) | small(466MB) | medium(1.5GB) | large(3GB)
# base is the best balance of speed vs accuracy on 12 GB RAM
STT_MODEL=base
STT_LANGUAGE=en


# ── MEMORY / VECTOR STORE ─────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
EMBEDDING_MODEL=all-MiniLM-L6-v2
MAX_MEMORY_RESULTS=10
MEMORY_SIMILARITY_THRESHOLD=0.7


# ── TRADING ───────────────────────────────────────────────────────────
DEFAULT_EXCHANGE=NSE
PAPER_TRADING_CAPITAL=100000.0

# Alpha Vantage — extra market data (free tier: 25 req/day)
# https://www.alphavantage.co/support/#api-key
# ALPHA_VANTAGE_KEY=...

# Finnhub — real-time data (free tier: 60 req/min)
# https://finnhub.io/register
# FINNHUB_KEY=...


# ── SECURITY ──────────────────────────────────────────────────────────
REQUIRE_APPROVAL_FOR_DANGEROUS=true
AUDIT_LOG_PATH=./data/audit.log


# ── PATHS ─────────────────────────────────────────────────────────────
DATA_DIR=./data
LOGS_DIR=./logs
